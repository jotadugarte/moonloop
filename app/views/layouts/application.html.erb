<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Moonloop" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Moonloop">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= javascript_importmap_tags %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <a class="skip-link" href="#main-content"><%= t("layout.skip_to_content") %></a>

    <% if Current.user %>
      <nav aria-label="<%= t('layout.nav.aria_label') %>">
        <%= link_to t("layout.nav.my_day"),   my_day_path %>
        <%= link_to t("layout.nav.catalogs"), public_menus_path %>
        <%= link_to t("layout.nav.reports"),  informes_path %>
        <%= link_to t("layout.nav.profile"),  edit_profile_path %>
      </nav>
    <% end %>

    <% if notice.present? %>
      <p class="flash flash--notice" role="status"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="flash flash--alert" role="alert"><%= alert %></p>
    <% end %>

    <main id="main-content">
      <%= yield %>
    </main>
  </body>
</html>
