<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<h1>Habit Categories</h1>

<%= form_with model: @habit_category, url: habit_categories_path do |f| %>
  <div>
    <%= f.label :name, "Name" %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.submit "Create Category" %>
  </div>
<% end %>

<hr>

<% @habit_categories.each do |category| %>
  <div id="<%= dom_id(category) %>">
    <strong><%= category.name %></strong>
    <%= link_to "Edit", edit_habit_category_path(category) %>
    <%= button_to "Delete", habit_category_path(category), method: :delete %>
  </div>
<% end %>

