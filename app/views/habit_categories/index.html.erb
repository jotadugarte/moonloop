<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<h1><%= t("habit_categories.index.title") %></h1>

<%= form_with model: @habit_category, url: habit_categories_path do |f| %>
  <div>
    <%= f.label :name, t("habit_categories.index.name_label") %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.submit t("habit_categories.index.create_submit") %>
  </div>
<% end %>

<hr>

<% @habit_categories.each do |category| %>
  <div id="<%= dom_id(category) %>">
    <strong><%= category.name %></strong>
    <%= link_to t("habit_categories.index.edit"), edit_habit_category_path(category) %>
    <%= button_to t("habit_categories.index.delete"), habit_category_path(category), method: :delete %>
  </div>
<% end %>

