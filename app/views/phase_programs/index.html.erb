<% content_for :title, t("phase_programs.index.title") %>

<h1 class="text-2xl font-bold mb-4"><%= t("phase_programs.index.heading") %></h1>

<p class="mb-4 flex flex-wrap gap-x-3 gap-y-1">
  <%= link_to t("phase_programs.index.back_phase"), phase_path, class: "text-blue-600 underline" %>
  <%= link_to t("phase_programs.index.catalog_link"), public_plans_path, class: "text-blue-600 underline" %>
</p>

<% prog_err_id = "phase-program-new-errors" %>
<%= form_with model: @phase_program, url: phase_programs_path, class: "space-y-3 max-w-lg mb-8" do |f| %>
  <% if @phase_program.errors.any? %>
    <ul id="<%= prog_err_id %>" class="text-red-600 text-sm list-disc pl-5" role="alert">
      <% @phase_program.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  <% end %>
  <div>
    <%= f.label :name, t("phase_programs.index.name_label"), class: "block font-medium mb-1" %>
    <%= f.text_field :name,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@phase_program, :name, prog_err_id) %>
  </div>
  <div class="flex items-center gap-2">
    <%= f.check_box :publicly_shareable,
          class: "rounded border-gray-300",
          aria: aria_for_field(@phase_program, :publicly_shareable, prog_err_id) %>
    <%= f.label :publicly_shareable, t("phase_programs.index.public_share_label"), class: "text-gray-700" %>
  </div>
  <div>
    <%= f.submit t("phase_programs.index.create_submit"),
          class: "bg-blue-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-blue-700 border-0" %>
  </div>
<% end %>

<hr class="mb-6">

<% @phase_programs.each do |program| %>
  <div id="<%= dom_id(program) %>" class="mb-2">
    <strong><%= program.name %></strong>
    <%= link_to t("phase_programs.index.edit"), edit_phase_program_path(program), class: "text-blue-600 underline ml-2" %>
  </div>
<% end %>
