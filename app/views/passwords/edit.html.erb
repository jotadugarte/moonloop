<h1><%= t("passwords.edit.title") %></h1>

<%= form_with(url: password_path, method: :patch) do |form| %>
  <% if @user.errors.any? %>
    <div style="color: red">
      <h2><%= t("forms.errors.header", count: @user.errors.count, model: @user.model_name.human) %></h2>

      <ul>
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :password_challenge, t("activerecord.attributes.user.password_challenge"), style: "display: block" %>
    <%= form.password_field :password_challenge, required: true, autofocus: true, autocomplete: "current-password" %>
  </div>

  <div>
    <%= form.label :password, t("passwords.edit.new_password"), style: "display: block" %>
    <%= form.password_field :password, required: true, autocomplete: "new-password" %>
    <div><%= t("passwords.edit.password_hint") %></div>
  </div>

  <div>
    <%= form.label :password_confirmation, t("passwords.edit.confirm_new_password"), style: "display: block" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>

  <div>
    <%= form.submit t("shared.save_changes") %>
  </div>
<% end %>

<br>

<div>
  <%= link_to t("shared.back"), root_path %>
</div>
