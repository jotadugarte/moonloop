<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<h1><%= t("sessions.new.title") %></h1>

<%= form_with(url: sign_in_path) do |form| %>
  <div>
    <%= form.label :email, t("activerecord.attributes.user.email"), style: "display: block" %>
    <%= form.email_field :email, value: params[:email_hint], required: true, autofocus: true, autocomplete: "email" %>
  </div>

  <div>
    <%= form.label :password, t("activerecord.attributes.user.password"), style: "display: block" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password" %>
  </div>

  <div>
    <%= form.submit t("sessions.new.submit") %>
  </div>
<% end %>

<br>


<br>

<div>
  <%= link_to t("sessions.new.sign_up"), sign_up_path %> |
  <%= link_to t("sessions.new.forgot_password"), new_identity_password_reset_path %>
</div>
