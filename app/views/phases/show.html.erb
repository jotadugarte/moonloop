<% content_for :title, t("phases.show.title") %>

<h1 class="text-2xl font-bold mb-4"><%= t("phases.show.heading") %></h1>

<% if @phase_start_in_app_reminder %>
  <div class="mb-6 rounded border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900" data-test="phase-start-reminder-banner" role="alert">
    <p class="font-medium mb-2"><%= t("phases.show.phase_start_reminder_banner") %></p>
    <%= button_to t("phases.show.phase_start_reminder_dismiss"),
                  dismiss_reminder_phase_path,
                  method: :post,
                  class: "text-sm bg-amber-700 text-white px-3 py-1.5 rounded cursor-pointer hover:bg-amber-800 border-0" %>
  </div>
<% end %>

<% if @plan_ended %>
  <div class="mb-6 rounded border border-slate-400 bg-slate-50 px-4 py-3 text-slate-900" data-test="phase-plan-ended-banner" role="status" aria-live="polite">
    <p class="font-medium mb-3"><%= t("phases.show.plan_ended_message") %></p>
    <div class="flex flex-wrap gap-3 items-center">
      <%= button_to t("phases.show.repeat_last_assignment"),
                    repeat_last_assignment_phase_path,
                    method: :post,
                    class: "text-sm bg-slate-800 text-white px-3 py-1.5 rounded cursor-pointer hover:bg-slate-900 border-0" %>
      <%= link_to t("phases.show.add_week_range"), new_phase_assignment_path, class: "text-sm text-blue-600 underline" %>
    </div>
  </div>
<% end %>

<section class="mb-8 space-y-2">
  <% if @week_index.present? %>
    <p><%= t("phases.show.current_week", index: @week_index) %></p>
  <% else %>
    <p class="text-gray-600"><%= t("phases.show.no_week_yet") %></p>
  <% end %>

  <% if @active_menu.present? %>
    <p>
      <%= t("phases.show.active_menu_label") %>
      <%= link_to @active_menu.name, edit_menu_path(@active_menu), class: "text-blue-600 underline font-medium" %>
    </p>
  <% elsif @week_index.present? %>
    <p class="text-gray-600"><%= t("phases.show.no_menu_for_week") %></p>
  <% end %>
</section>

<section class="mb-8 max-w-md">
  <h2 class="text-lg font-semibold mb-2"><%= t("phases.show.anchor_heading") %></h2>
  <% phase_user_err_id = "phase-user-form-errors" %>
  <%= form_with model: @user, url: phase_path, method: :patch, class: "space-y-3" do |f| %>
    <% if @user.errors.any? %>
      <ul id="<%= phase_user_err_id %>" class="text-red-600 text-sm list-disc pl-5" role="alert">
        <% @user.errors.each do |err| %>
          <li><%= err.full_message %></li>
        <% end %>
      </ul>
    <% end %>
    <div>
      <%= f.label :phase_one_starts_on, t("phases.show.anchor_label"), class: "block font-medium mb-1" %>
      <%= f.date_field :phase_one_starts_on,
            class: "border border-gray-300 rounded p-2 w-full",
            aria: aria_for_field(@user, :phase_one_starts_on, phase_user_err_id) %>
    </div>
    <div>
      <%= f.submit t("phases.show.anchor_submit"), class: "bg-blue-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-blue-700" %>
    </div>
  <% end %>
</section>

<section class="mb-8">
  <div class="flex items-center gap-4 mb-3">
    <h2 class="text-lg font-semibold"><%= t("phases.show.assignments_heading") %></h2>
    <%= link_to t("phases.show.new_assignment"), new_phase_assignment_path, class: "text-blue-600 underline text-sm" %>
  </div>

  <% if @assignments.any? %>
    <table class="border-collapse text-left text-sm">
      <thead>
        <tr>
          <th class="border border-gray-200 px-2 py-1"><%= t("phases.show.table.menu") %></th>
          <th class="border border-gray-200 px-2 py-1"><%= t("phases.show.table.weeks") %></th>
          <th class="border border-gray-200 px-2 py-1"></th>
        </tr>
      </thead>
      <tbody>
        <% @assignments.each do |a| %>
          <tr>
            <td class="border border-gray-200 px-2 py-1"><%= a.menu.name %></td>
            <td class="border border-gray-200 px-2 py-1"><%= a.start_week %>–<%= a.end_week %></td>
            <td class="border border-gray-200 px-2 py-1">
              <%= link_to t("phases.show.edit_assignment"), edit_phase_assignment_path(a), class: "text-blue-600 underline" %>
              <%= button_to t("phases.show.delete_assignment"), phase_assignment_path(a), method: :delete, class: "text-red-600 bg-transparent border-0 underline cursor-pointer p-0 inline text-sm", form: { class: "inline", data: { turbo_confirm: t("phases.show.delete_assignment_confirm") } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-600 text-sm"><%= t("phases.show.assignments_empty") %></p>
  <% end %>
</section>

<p>
  <%= link_to t("phases.show.back_home"), root_path, class: "text-blue-600 underline" %>
  ·
  <%= link_to t("phases.show.menus_link"), menus_path, class: "text-blue-600 underline" %>
</p>
