<% content_for :title, t("public_plans.show.title", name: @plan.name) %>

<h1><%= @plan.name %></h1>

<p><%= t("public_plans.shared.author", code: @plan.user.public_catalog_author_code) %></p>

<% if Current.user && Current.user.id != @plan.user_id %>
  <section class="mb-4" aria-label="<%= t("public_plans.adopt.section_label") %>">
    <%= form_with url: adopt_public_plan_path(@plan), method: :post, local: true do |f| %>
      <p>
        <%= label_tag "adopt_plan_copy_name", t("public_plans.adopt.name_label") %>
        <%= text_field_tag :name, params[:name].presence || @plan.name,
              id: "adopt_plan_copy_name",
              required: true,
              aria: { required: true } %>
      </p>
      <p><%= f.submit t("public_plans.adopt.submit") %></p>
    <% end %>
  </section>
<% end %>

<section class="mb-6" aria-labelledby="public-plan-assignments-heading">
  <h2 id="public-plan-assignments-heading" class="text-lg font-semibold mb-2">
    <%= t("public_plans.show.segments_heading") %>
  </h2>
  <% if @assignments.any? %>
    <ul class="list-disc pl-5 space-y-1">
      <% @assignments.each do |a| %>
        <li>
          <%= t("public_plans.show.segment_line",
                menu: a.menu.name,
                routine: a.exercise_routine.name,
                start: a.start_week,
                end: a.end_week) %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600"><%= t("public_plans.show.no_segments") %></p>
  <% end %>
</section>

<p><%= link_to t("public_plans.show.back_to_catalog"), public_plans_path, class: "text-blue-600 underline" %></p>
