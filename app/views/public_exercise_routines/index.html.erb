<% content_for :title, t("public_exercise_routines.index.title") %>

<h1><%= t("public_exercise_routines.index.heading") %></h1>

<ul role="list">
  <% @routines.each do |routine| %>
    <article>
      <%= link_to routine.name, public_exercise_routine_path(routine) %>
      — <%= t("public_exercise_routines.shared.author", code: routine.user.public_catalog_author_code) %>
      <%= render "shared/catalog_index_metrics", record: routine %>
    </article>
  <% end %>
</ul>
