<% frame_id = dom_id(menu, "slot_#{weekday}_#{meal_type}") %>
<% slot_err_id = dom_id(menu, "entry_errors_#{weekday}_#{meal_type}") %>
<% allow_freeform = Current.user.allow_menu_freeform %>
<% slot_key = "menu-slot-#{menu.id}-#{weekday}-#{meal_type}" %>
<% dish_select_id = "#{slot_key}-dish" %>
<% dish_filter_id = "#{slot_key}-dish-filter" %>
<% freeform_input_id = "#{slot_key}-freeform" %>
<% meal_type_keys = Menus::MealType::KEYS %>
<% group_order = ([ meal_type ] + meal_type_keys).uniq %>
<% selected_dish_name = dishes.find { |dish| dish.id == entry&.dish_id }&.name.to_s %>
<% selected_picker_value = entry&.dish_id.present? ? selected_dish_name : t("menus.slots.dish_blank") %>

<%= turbo_frame_tag frame_id do %>
  <div
    class="menu-grid__slot"
    data-test="menu-entry-slot"
    data-weekday="<%= weekday %>"
    data-meal-type="<%= meal_type %>"
    data-controller="menu-slot"
    data-menu-slot-freeform-id-value="<%= freeform_input_id %>"
  >
    <div class="menu-grid__slot-label">
      <%= t("date.day_names")[weekday] %>
    </div>

    <% preview = Menus::SlotPreview.call(entry: entry, meal_type: meal_type) %>
    <% if preview %>
      <div class="menu-grid__slot-preview">
        <%= menu_slot_preview_image_tag(preview, meal_type) %>
      </div>
    <% end %>

    <%= form_with model: (entry || MenuEntry.new),
          url: menu_menu_entries_path(menu),
          method: :post,
          scope: :menu_entry,
          data: { turbo_frame: frame_id, controller: "autosubmit" } do |f| %>
      <%= f.hidden_field :weekday, value: weekday %>
      <%= f.hidden_field :meal_type, value: meal_type %>

      <% if entry&.errors&.any? %>
        <ul id="<%= slot_err_id %>" class="text-red-600 text-sm mb-2 list-disc pl-5" role="alert">
          <% entry.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>

      <div>
        <%= f.label :dish_id, t("menus.slots.dish_pick_label"), for: dish_filter_id %>

        <div
          class="mt-2"
          data-controller="dish-picker"
          data-dish-picker-selected-dish-name-value="<%= selected_picker_value %>"
        >
          <%= f.hidden_field :dish_id,
                value: entry&.dish_id,
                id: dish_select_id,
                data: { dish_picker_target: "dishId" },
                aria: aria_for_field(f.object, :dish_id, slot_err_id) %>

          <input
            id="<%= dish_filter_id %>"
            type="text"
            class="border border-gray-300 rounded p-2 w-full"
            autocomplete="off"
            value="<%= selected_picker_value %>"
            placeholder="<%= t("menus.slots.dish_picker_filter_placeholder") %>"
            aria-label="<%= t("menus.slots.dish_picker_filter_aria") %>"
            data-test="dish-picker-filter"
            data-dish-picker-target="filter"
            data-action="focus->dish-picker#open input->dish-picker#filter"
          >

          <button
            type="button"
            class="mt-2 text-sm underline text-gray-700"
            data-test="dish-picker-clear"
            data-action="click->dish-picker#clear"
          >
            <%= t("menus.slots.dish_blank") %>
          </button>

          <p class="hidden mt-2 text-sm text-gray-600" data-dish-picker-target="noResults">
            <%= t("menus.slots.dish_picker_no_results") %>
          </p>

          <div class="hidden mt-2 space-y-2" data-dish-picker-target="groups">
            <% group_order.each do |group_key| %>
              <% group_items = (dishes_by_meal_type[group_key] || []) %>
              <% next if group_items.empty? %>

              <div data-test="dish-picker-group" data-meal-type="<%= group_key %>">
                <div class="font-medium text-sm text-gray-700 mb-1">
                  <%= t("menus.meal_types.#{group_key}") %>
                </div>
                <ul role="list" class="space-y-1">
                  <% group_items.each do |dish| %>
                    <% selected = entry&.dish_id == dish.id %>
                    <li>
                      <button
                        type="button"
                        class="text-left w-full border rounded px-2 py-1 hover:bg-gray-50 <%= selected ? "border-blue-400 bg-blue-50" : "border-gray-200" %>"
                        data-test="dish-picker-option"
                        data-dish-id="<%= dish.id %>"
                        data-dish-name="<%= dish.name %>"
                        data-action="click->dish-picker#pick"
                        aria-pressed="<%= selected %>"
                      >
                        <%= dish.name %>
                      </button>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% if allow_freeform %>
        <div>
          <%= f.label :freeform_text, t("menus.slots.freeform_label"), for: freeform_input_id %>
          <%= f.text_field :freeform_text,
                value: entry&.freeform_text,
                id: freeform_input_id,
                aria: aria_for_field(f.object, :freeform_text, slot_err_id),
                data: { action: "blur->autosubmit#submit", turbo_permanent: true } %>
        </div>
      <% elsif entry&.freeform_text.present? && entry.dish_id.blank? %>
        <p class="text-sm text-gray-600 mt-2">
          <%= t("menus.slots.legacy_freeform_hint") %>
          <span class="font-medium"><%= entry.freeform_text %></span>
        </p>
      <% end %>

    <% end %>

    <div>
      <%= button_to t("menus.slots.clear_submit"),
            clear_menu_menu_entries_path(menu),
            method: :delete,
            params: { weekday: weekday, meal_type: meal_type },
            form: { data: { turbo_frame: frame_id, action: "turbo:submit-end->menu-slot#clearDone" } } %>
    </div>
  </div>
<% end %>
