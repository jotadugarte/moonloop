<% content_for :title, t("my_day.show.page_title") %>

<h1><%= t("my_day.show.heading") %></h1>

<%= form_with url: my_day_path, method: :get, local: true, class: "my-day-date-picker" do %>
  <label for="fecha"><%= t("my_day.show.date_label") %></label>
  <input type="date" id="fecha" name="fecha" value="<%= @local_date %>" max="<%= @max_date %>">
  <button type="submit"><%= t("my_day.show.go_to_date") %></button>
<% end %>

<p class="my-day-date"><%= l(@local_date, format: :long) %></p>

<% if @local_date < @max_date %>
  <p><%= link_to t("my_day.show.view_today"), my_day_path %></p>
<% end %>

<% if @due_habits.empty? %>
  <p><%= t("my_day.show.empty") %></p>
<% else %>
  <ul class="my-day-habits">
    <% @due_habits.each do |habit| %>
      <% completion = @completions_by_habit_id[habit.id] %>
      <li id="<%= dom_id(habit) %>" data-habit-streak="<%= @streak_by_habit_id[habit.id] %>">
        <span class="my-day-habit-name"><%= habit.name %></span>
        <span class="my-day-habit-category"><%= habit.habit_category.name %></span>
        <span class="my-day-habit-streak"><%= t("my_day.show.streak_display", count: @streak_by_habit_id[habit.id]) %></span>
        <% if completion %>
          <span class="my-day-habit-status"><%= t("habit_completions.status.#{completion.status}") %></span>
        <% end %>
        <fieldset class="my-day-actions">
          <legend class="my-day-actions-legend"><%= t("my_day.show.actions_legend") %></legend>
          <%= button_to t("my_day.actions.mark_done"),
                habit_completions_path,
                method: :post,
                params: {
                  habit_completion: {
                    user_habit_id: habit.id,
                    completed_on: @local_date.iso8601,
                    status: "done"
                  }
                } %>
          <%= button_to t("my_day.actions.mark_failed"),
                habit_completions_path,
                method: :post,
                params: {
                  habit_completion: {
                    user_habit_id: habit.id,
                    completed_on: @local_date.iso8601,
                    status: "failed"
                  }
                } %>
          <% if completion %>
            <%= button_to t("my_day.actions.clear"),
                  habit_completion_path(completion),
                  method: :delete %>
          <% end %>
        </fieldset>
        <% if habit.global_habit_template&.code == "fitness_exercise" %>
          <div class="my-day-exercise-inline mt-3 pl-2 border-l-2 border-gray-300" data-test="my-day-exercise-inline">
            <p class="text-sm font-medium text-gray-900"><%= t("my_day.show.exercise_inline_heading") %></p>
            <% if @active_exercise_routine %>
              <p class="text-sm text-gray-800"><%= @active_exercise_routine.name %></p>
              <% if @exercise_preview_lines.any? %>
                <ul class="list-disc list-inside text-sm text-gray-700 my-1">
                  <% @exercise_preview_lines.each do |line| %>
                    <li><%= line.label %></li>
                  <% end %>
                </ul>
              <% else %>
                <p class="text-sm text-gray-600"><%= t("my_day.show.exercise_no_lines_this_day") %></p>
              <% end %>
              <p class="mt-1">
                <%= link_to t("my_day.show.exercise_full_week_link"),
                      edit_exercise_routine_path(@active_exercise_routine),
                      class: "text-blue-600 underline text-sm font-medium",
                      data: { turbo_action: "advance" } %>
              </p>
            <% else %>
              <p class="text-sm text-gray-600"><%= t("my_day.show.exercise_no_routine_this_week") %></p>
            <% end %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>

<% if @fitness_exercise_habit && !@fitness_exercise_habit.active? %>
  <section
    class="mt-6 p-4 rounded border border-gray-200 bg-gray-50 opacity-80"
    data-test="my-day-exercise-inactive"
    aria-disabled="true">
    <h2 class="text-base font-semibold text-gray-700"><%= t("my_day.show.exercise_inactive_heading") %></h2>
    <p class="text-sm text-gray-600 mt-1"><%= t("my_day.show.exercise_inactive_body") %></p>
    <p class="mt-2">
      <%= link_to t("my_day.show.exercise_inactive_cta"),
            user_habits_path,
            class: "text-blue-600 underline text-sm font-medium",
            data: { turbo_action: "advance" } %>
    </p>
  </section>
<% end %>

<section class="mt-8 pt-6 border-t border-gray-200" data-test="my-day-exercise-shortcut">
  <h2 class="text-lg font-semibold mb-2"><%= t("my_day.show.exercise_shortcut_heading") %></h2>
  <p class="text-gray-700 text-sm mb-2"><%= t("my_day.show.exercise_shortcut_intro") %></p>
  <div class="flex flex-wrap gap-x-4 gap-y-1">
    <%= link_to t("my_day.show.exercise_shortcut_routines"),
          exercise_routines_path,
          class: "text-blue-600 underline font-medium",
          data: { turbo_action: "advance" } %>
    <span class="text-gray-400" aria-hidden="true">·</span>
    <%= link_to t("my_day.show.exercise_shortcut_phase_plan"),
          phase_path,
          class: "text-blue-600 underline font-medium",
          data: { turbo_action: "advance" } %>
  </div>
</section>

<section class="mt-8 pt-6 border-t border-gray-200" data-test="my-day-phases-shortcut">
  <h2 class="text-lg font-semibold mb-2"><%= t("my_day.show.phases_shortcut_heading") %></h2>
  <p class="text-gray-700 text-sm mb-2"><%= t("my_day.show.phases_shortcut_intro") %></p>
  <%= link_to t("my_day.show.phases_shortcut_link"),
              phase_path,
              class: "text-blue-600 underline font-medium",
              data: { turbo_action: "advance" } %>
</section>

<p><%= link_to t("my_day.show.back_home"), root_path %></p>
