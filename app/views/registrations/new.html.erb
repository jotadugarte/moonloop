<h1 class="text-2xl font-bold mb-4"><%= t(".title") %></h1>

<% registration_err_id = "registration-form-errors" %>
<%= form_with model: @user, url: sign_up_path, class: "space-y-4 max-w-md", data: { controller: "unit-system-toggle" } do |form| %>
  <% if @user.errors.any? %>
    <div class="text-red-600 mb-4">
      <h2 class="font-bold"><%= t("forms.errors.header", count: @user.errors.count, model: @user.model_name.human) %></h2>
      <ul id="<%= registration_err_id %>" class="list-disc pl-5" role="alert">
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :email, class: "block font-medium mb-1 text-gray-700" %>
    <%= form.email_field :email,
          required: true,
          autofocus: true,
          autocomplete: "email",
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@user, :email, registration_err_id) %>
  </div>

  <div>
    <%= form.label :password, class: "block font-medium mb-1 text-gray-700" %>
    <%= form.password_field :password,
          required: true,
          autocomplete: "new-password",
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@user, :password, registration_err_id) %>
    <div class="text-sm text-gray-500 mt-1"><%= t(".password_hint") %></div>
  </div>

  <div>
    <%= form.label :password_confirmation, class: "block font-medium mb-1 text-gray-700" %>
    <%= form.password_field :password_confirmation,
          required: true,
          autocomplete: "new-password",
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@user, :password_confirmation, registration_err_id) %>
  </div>

  <%= render "shared/birth_date_fields",
        form: form,
        error_summary_id: registration_err_id,
        dom_prefix: "registration" %>

  <fieldset class="border border-gray-200 rounded p-3 space-y-2">
    <legend class="font-medium text-gray-800 px-1"><%= t(".body_unit_system_legend") %></legend>
    <% User::BODY_UNIT_SYSTEMS.each do |system| %>
      <div class="flex items-center gap-2">
        <%= form.radio_button :body_unit_system, system,
              checked: (@user.body_unit_system == system || (@user.body_unit_system.nil? && system == "metric")),
              aria: { describedby: "registration-body-units-hint" },
              data: {
                unit_system_toggle_target: "unitRadio",
                action: "change->unit-system-toggle#toggle"
              } %>
        <%= form.label :body_unit_system, t(".units.#{system}"), value: system, class: "text-gray-700" %>
      </div>
    <% end %>
    <p id="registration-body-units-hint" class="text-sm text-gray-500"><%= t(".body_unit_system_hint") %></p>
  </fieldset>

  <% imperial_height = registration_imperial_height_for_toggle?(@user) %>
  <% height_cm_aria = aria_for_field(@user, :height_cm, registration_err_id) %>
  <div data-unit-system-toggle-target="metric"<% if imperial_height %> class="hidden"<% end %>>
    <%= form.label :height_cm, class: "block font-medium mb-1 text-gray-700" %>
    <%= form.number_field :height_cm,
          min: 50,
          max: 300,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: height_cm_aria %>
    <p class="text-sm text-gray-500 mt-1"><%= t(".height_cm_hint_metric") %></p>
  </div>

  <div data-unit-system-toggle-target="imperial"<% unless imperial_height %> class="hidden"<% end %>>
    <%= label_tag "user_registration_height_feet", t(".height_feet"), class: "block font-medium mb-1 text-gray-700" %>
    <%= number_field_tag "user[height_feet]", @reg_height_feet,
          id: "user_registration_height_feet",
          min: 0,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: height_cm_aria %>
  </div>

  <div data-unit-system-toggle-target="imperial"<% unless imperial_height %> class="hidden"<% end %>>
    <%= label_tag "user_registration_height_inches", t(".height_inches"), class: "block font-medium mb-1 text-gray-700" %>
    <%= number_field_tag "user[height_inches]", @reg_height_inches,
          id: "user_registration_height_inches",
          min: 0,
          max: 11,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: height_cm_aria %>
    <p class="text-sm text-gray-500 mt-1"><%= t(".height_imperial_hint") %></p>
  </div>

  <div data-controller="timezone-autodetect">
    <%= form.label :timezone, class: "block font-medium mb-1 text-gray-700" %>
    <%= form.select :timezone,
          ActiveSupport::TimeZone.all.map { |tz| [ "(GMT#{tz.formatted_offset}) #{tz.name}", tz.tzinfo.name ] },
          { prompt: t("shared.timezone_select_prompt") },
          { required: true,
            data: { timezone_autodetect_target: "input" },
            class: "border border-gray-300 rounded p-2 w-full",
            aria: aria_for_field(@user, :timezone, registration_err_id) } %>
  </div>

  <% weight_hint_text = t(".weight_optional_hint") %>
  <div data-unit-system-toggle-target="metric">
    <%= form.label :weight_kg, t(".weight_kg_label"), class: "block font-medium mb-1 text-gray-700" %>
    <%= form.number_field :weight_kg,
          min: 20,
          max: 500,
          step: 0.1,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: { describedby: "registration-weight-optional-hint" } %>
  </div>

  <div data-unit-system-toggle-target="imperial" class="hidden">
    <%= label_tag "user_registration_weight_lb", t(".weight_lb_label"), class: "block font-medium mb-1 text-gray-700" %>
    <%= number_field_tag "user[weight_lb]", nil,
          id: "user_registration_weight_lb",
          min: 44,
          max: 1102,
          step: 0.1,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: { describedby: "registration-weight-optional-hint" } %>
  </div>

  <p id="registration-weight-optional-hint" data-test="registration-weight-optional-hint" class="text-sm text-gray-500">
    <%= weight_hint_text %>
  </p>

  <div class="pt-4">
    <%= form.submit t(".submit"), class: "bg-blue-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-blue-700" %>
  </div>
<% end %>

<p class="mt-4 text-sm text-gray-600">
  <%= link_to t("registrations.new.back_to_sign_in"), sign_in_path, class: "text-blue-600 underline hover:text-blue-800" %>
</p>
