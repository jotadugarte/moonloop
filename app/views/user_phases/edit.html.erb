<% content_for :title, t("user_phases.edit.title", name: @phase.name) %>

<h1 class="text-2xl font-bold mb-4"><%= t("user_phases.edit.heading", name: @phase.name) %></h1>

<% phs_attrs_err_id = "user-phase-attrs-errors" %>
<%= form_with model: @phase, url: user_phase_path(@phase), method: :patch, class: "space-y-3 max-w-lg mb-8" do |f| %>
  <% if @phase.errors.any? || @phase.catalog_listing_facet&.errors&.any? %>
    <ul id="<%= phs_attrs_err_id %>" class="text-red-600 text-sm list-disc pl-5" role="alert">
      <% @phase.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
      <% @phase.catalog_listing_facet&.errors&.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  <% end %>
  <div>
    <%= f.label :name, t("user_phases.edit.name_label"), class: "block font-medium mb-1" %>
    <%= f.text_field :name,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@phase, :name, phs_attrs_err_id) %>
  </div>
  <div>
    <%= f.label :weeks_total, t("user_phases.edit.weeks_total_label"), class: "block font-medium mb-1" %>
    <%= f.number_field :weeks_total,
          min: 1,
          step: 1,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@phase, :weeks_total, phs_attrs_err_id) %>
  </div>
  <div class="flex items-center gap-2">
    <%= f.check_box :publicly_shareable,
          class: "rounded border-gray-300",
          aria: aria_for_field(@phase, :publicly_shareable, phs_attrs_err_id) %>
    <%= f.label :publicly_shareable, t("user_phases.edit.public_share_label"), class: "text-gray-700" %>
  </div>
  <%= f.fields_for(:catalog_listing_facet, @phase.catalog_listing_facet || @phase.build_catalog_listing_facet) do |cf| %>
    <%= render "shared/catalog_listing_facet_fields", cf: cf %>
  <% end %>
  <div>
    <%= f.submit t("user_phases.edit.save_submit"),
          class: "bg-blue-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-blue-700 border-0" %>
  </div>
<% end %>

<section class="mb-8 max-w-2xl">
  <h2 class="text-lg font-semibold mb-2"><%= t("user_phases.edit.blocks_heading") %></h2>
  <p class="text-gray-600 text-sm"><%= t("user_phases.edit.blocks_hint") %></p>
</section>

<section class="mb-8">
  <%= button_to t("user_phases.edit.destroy_phase"),
        user_phase_path(@phase),
        method: :delete,
        form: { data: { turbo_confirm: t("user_phases.edit.destroy_confirm") } },
        class: "text-sm bg-red-700 text-white px-3 py-2 rounded cursor-pointer hover:bg-red-800 border-0" %>
</section>

<p>
  <%= link_to t("user_phases.edit.back_index"), user_phases_path, class: "text-blue-600 underline" %>
  ·
  <%= link_to t("user_phases.edit.back_home"), root_path, class: "text-blue-600 underline" %>
</p>
