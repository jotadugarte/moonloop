<% content_for :title, t("reports.show.page_title") %>

<h1><%= t("reports.show.heading") %></h1>

<% section = params[:section].to_s %>
<% section = "fulfillment" unless %w[fulfillment streaks weight].include?(section) %>

<nav class="reports-section-nav" aria-label="<%= t("reports.show.section_nav_aria") %>">
  <%= link_to t("reports.show.nav_fulfillment"), informes_path(fecha: params[:fecha], section: "fulfillment"), class: (section == "fulfillment" ? "reports-section-nav__link reports-section-nav__link--active" : "reports-section-nav__link"), aria: (section == "fulfillment" ? { current: "page" } : {}) %>
  <%= t("ui.inline_sep") %>
  <%= link_to t("reports.show.nav_streaks"), informes_path(fecha: params[:fecha], section: "streaks"), class: (section == "streaks" ? "reports-section-nav__link reports-section-nav__link--active" : "reports-section-nav__link"), aria: (section == "streaks" ? { current: "page" } : {}) %>
  <%= t("ui.inline_sep") %>
  <%= link_to t("reports.show.nav_weight"), informes_path(fecha: params[:fecha], section: "weight"), class: (section == "weight" ? "reports-section-nav__link reports-section-nav__link--active" : "reports-section-nav__link"), aria: (section == "weight" ? { current: "page" } : {}) %>
</nav>

<%= form_with url: informes_path, method: :get, local: true, class: "reports-date-picker" do %>
  <label for="fecha"><%= t("reports.show.date_label") %></label>
  <%= hidden_field_tag :section, section %>
  <input type="date" id="fecha" name="fecha" value="<%= @local_date %>" max="<%= @max_date %>">
  <button type="submit"><%= t("reports.show.go_to_date") %></button>
<% end %>

<% if @local_date < @max_date %>
  <p><%= link_to t("reports.show.view_today"), informes_path(section: section) %></p>
<% end %>

<% if section == "fulfillment" %>
  <% week_start = l(@week_range.begin, format: :reports_week_range_start) %>
  <% week_end = l(@week_range.end, format: :long) %>
  <% month_s = l(@month_range.begin, format: :reports_month) %>
  <section class="reports-section" data-test="reports-fulfillment">
    <h2><%= t("reports.show.fulfillment_heading") %></h2>
    <p class="reports-range-hint"><%= t("reports.show.fulfillment_week_range", start: week_start, end: week_end) %></p>
    <p class="reports-range-hint"><%= t("reports.show.fulfillment_month_range", month: month_s) %></p>

    <% if @fulfillment_rows.empty? %>
      <p><%= t("reports.show.fulfillment_empty") %></p>
    <% else %>
      <table class="reports-table">
        <thead>
          <tr>
            <th scope="col"><%= t("reports.show.col_category") %></th>
            <th scope="col"><%= t("reports.show.col_habit") %></th>
            <th scope="col"><%= t("reports.show.col_week") %></th>
            <th scope="col"><%= t("reports.show.col_month") %></th>
          </tr>
        </thead>
        <tbody>
          <% @fulfillment_rows.each do |row| %>
            <tr>
              <td><%= row[:habit].habit_category.name %></td>
              <td><%= row[:habit].name %></td>
              <td><%= reports_fulfillment_cell(row[:week_stats]) %></td>
              <td><%= reports_fulfillment_cell(row[:month_stats]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </section>
<% end %>

<% if section == "streaks" %>
  <section class="reports-section" data-test="reports-streaks">
    <h2><%= t("reports.show.streaks_heading") %></h2>
    <% if @streak_rows.empty? %>
      <p><%= t("reports.show.streaks_empty") %></p>
    <% else %>
      <table class="reports-table">
        <thead>
          <tr>
            <th scope="col"><%= t("reports.show.col_category") %></th>
            <th scope="col"><%= t("reports.show.col_habit") %></th>
            <th scope="col"><%= t("reports.show.col_current_streak") %></th>
            <th scope="col"><%= t("reports.show.col_longest_streak") %></th>
          </tr>
        </thead>
        <tbody>
          <% @streak_rows.each do |row| %>
            <tr>
              <td><%= row[:habit].habit_category.name %></td>
              <td><%= row[:habit].name %></td>
              <td><%= t("reports.show.streak_days", count: row[:current]) %></td>
              <td><%= t("reports.show.streak_days", count: row[:longest]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </section>
<% end %>

<% if section == "weight" %>
  <section class="reports-section" data-test="reports-weight">
    <h2><%= t("reports.show.weight_heading") %></h2>
    <%= reports_weight_chart_tag(@weight_series, timezone: Current.user.timezone) %>
  </section>
<% end %>

<p><%= link_to t("reports.show.back_home"), root_path %></p>
