<h1><%= t("identity.password_resets.edit.title") %></h1>

<%= form_with(url: identity_password_reset_path, method: :patch) do |form| %>
  <% if @user.errors.any? %>
    <div style="color: red">
      <ul>
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :sid, value: params[:sid] %>

  <div>
    <%= form.label :password, t("passwords.edit.new_password"), style: "display: block" %>
    <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password" %>
    <div><%= t("passwords.edit.password_hint") %></div>
  </div>

  <div>
    <%= form.label :password_confirmation, t("passwords.edit.confirm_new_password"), style: "display: block" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>

  <div>
    <%= form.submit t("shared.save_changes") %>
  </div>
<% end %>
