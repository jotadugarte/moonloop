<h1><%= t("identity.password_resets.new.title") %></h1>

<%= form_with(url: identity_password_reset_path) do |form| %>
  <div>
    <%= form.label :email, t("activerecord.attributes.user.email"), style: "display: block" %>
    <%= form.email_field :email, required: true, autofocus: true %>
  </div>

  <div>
    <%= form.submit t("identity.password_resets.new.submit") %>
  </div>
<% end %>
