<% recipe_err_id = "recipe-form-errors" %>
<%= form_with model: @recipe, class: "space-y-4 max-w-lg" do |f| %>
  <% if @recipe.errors.any? %>
    <div class="text-red-600">
      <h2 class="font-bold"><%= t("recipes.form.errors_header", count: @recipe.errors.count) %></h2>
      <ul id="<%= recipe_err_id %>" class="list-disc pl-5" role="alert">
        <% @recipe.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("recipes.form.name_label"), class: "block font-medium mb-1" %>
    <%= f.text_field :name,
          required: true,
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@recipe, :name, recipe_err_id) %>
  </div>

  <div>
    <%= f.label :instructions, t("recipes.form.instructions_label"), class: "block font-medium mb-1" %>
    <%= f.text_area :instructions,
          rows: 8,
          class: "border border-gray-300 rounded p-2 w-full font-mono text-sm",
          aria: aria_for_field(@recipe, :instructions, recipe_err_id) %>
  </div>

  <div>
    <%= f.label :meal_type, t("recipes.form.meal_type_label"), class: "block font-medium mb-1" %>
    <%= f.select :meal_type,
          Menus::MealType::KEYS.map { |key| [ t("menus.meal_types.#{key}"), key ] },
          {},
          class: "border border-gray-300 rounded p-2 w-full",
          aria: aria_for_field(@recipe, :meal_type, recipe_err_id) %>
  </div>

  <div data-controller="recipe-image-preview">
    <div>
      <%= f.label :image, t("recipes.form.image_label"), class: "block font-medium mb-1" %>
      <%= f.file_field :image,
            accept: "image/*",
            class: "block w-full text-sm",
            aria: aria_for_field(@recipe, :image, recipe_err_id),
            data: {
              recipe_image_preview_target: "file",
              action: "change->recipe-image-preview#showPreview"
            } %>
    </div>
    <div
      class="hidden mt-2"
      data-recipe-image-preview-target="wrapper"
      data-test="recipe-image-preview">
      <%= image_tag "",
            alt: t("recipes.form.image_preview_alt"),
            class: "rounded max-w-xs border border-gray-200",
            data: { recipe_image_preview_target: "image" } %>
    </div>
  </div>

  <% if @recipe.image.attached? %>
    <div>
      <%= attachable_image_tag @recipe.image,
            resize_to_limit: [ 320, 320 ],
            class: "rounded max-w-xs border border-gray-200",
            alt: @recipe.name %>
    </div>
    <div class="flex items-start gap-2">
      <%= f.check_box :remove_image, class: "mt-1" %>
      <%= f.label :remove_image, t("recipes.form.remove_image_label"), class: "text-gray-700" %>
    </div>
  <% end %>

  <div class="flex items-start gap-2">
    <%= f.check_box :publicly_shareable,
          class: "mt-1",
          aria: aria_for_field(@recipe, :publicly_shareable, recipe_err_id) %>
    <%= f.label :publicly_shareable, t("recipes.form.public_label"), class: "text-gray-700" %>
  </div>

  <div>
    <%= f.submit(
          @recipe.new_record? ? t("recipes.form.create_submit") : t("recipes.form.update_submit"),
          class: "bg-blue-600 text-white px-4 py-2 rounded cursor-pointer hover:bg-blue-700"
        ) %>
  </div>
<% end %>
