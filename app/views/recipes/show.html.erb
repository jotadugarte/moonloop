<% content_for :title, t("recipes.show.title", name: @recipe.name) %>

<h1 class="text-2xl font-bold mb-2"><%= @recipe.name %></h1>

<% if @recipe.publicly_shareable %>
  <p class="text-sm text-gray-600 mb-4"><%= t("recipes.show.public_badge") %></p>
<% end %>

<% if @recipe.image.attached? %>
  <div class="mb-4">
    <%= attachable_image_tag @recipe.image,
          resize_to_limit: [ 480, 480 ],
          class: "rounded max-w-md border border-gray-200",
          alt: @recipe.name,
          loading: "eager" %>
  </div>
<% end %>

<% if @recipe.instructions.present? %>
  <div class="prose max-w-none mb-6">
    <h2 class="text-lg font-semibold mb-2"><%= t("recipes.show.instructions_heading") %></h2>
    <pre class="whitespace-pre-wrap font-sans text-gray-800 border border-gray-100 rounded p-3 bg-gray-50"><%= @recipe.instructions %></pre>
  </div>
<% else %>
  <p class="text-gray-600 mb-6"><%= t("recipes.show.no_instructions") %></p>
<% end %>

<div class="flex flex-wrap gap-4">
  <%= link_to t("recipes.show.edit"), edit_recipe_path(@recipe), class: "text-blue-600 underline" %>
  <%= link_to t("recipes.show.back_index"), recipes_path, class: "text-blue-600 underline" %>
  <%= button_to t("recipes.show.delete"), recipe_path(@recipe), method: :delete, class: "text-red-600 bg-transparent border-0 underline cursor-pointer p-0", form: { data: { turbo_confirm: t("recipes.show.delete_confirm") } } %>
</div>
