<% content_for :title, t("public_phase_programs.show.title", name: @program.name) %>

<h1><%= @program.name %></h1>

<p><%= t("public_phase_programs.shared.author", code: @program.user.public_catalog_author_code) %></p>

<section class="mb-6" aria-labelledby="public-program-segments-heading">
  <h2 id="public-program-segments-heading" class="text-lg font-semibold mb-2">
    <%= t("public_phase_programs.show.segments_heading") %>
  </h2>
  <% if @assignments.any? %>
    <ul class="list-disc pl-5 space-y-1">
      <% @assignments.each do |a| %>
        <li>
          <%= t("public_phase_programs.show.segment_line",
                menu: a.menu.name,
                routine: a.exercise_routine.name,
                start: a.start_week,
                end: a.end_week) %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600"><%= t("public_phase_programs.show.no_segments") %></p>
  <% end %>
</section>

<p><%= link_to t("public_phase_programs.show.back_to_catalog"), public_phase_programs_path, class: "text-blue-600 underline" %></p>
