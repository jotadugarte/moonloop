<h1><%= t("user_habits.index.title") %></h1>

<h2><%= t("user_habits.index.create_personal_title") %></h2>
<% if @user_habit.errors.any? %>
  <div id="user_habit_errors" role="alert">
    <%= @user_habit.errors.full_messages.to_sentence %>
  </div>
<% end %>
<%= form_with model: @user_habit, url: user_habits_path do |f| %>
  <div>
    <%= f.label :habit_category_id, t("user_habits.index.category_label") %>
    <%= f.select :habit_category_id, @categories.map { |c| [c.name, c.id] } %>
  </div>
  <div>
    <%= f.label :name, t("user_habits.index.name_label") %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.submit t("user_habits.index.create_personal_submit") %>
  </div>
<% end %>

<hr>

<h2><%= t("user_habits.index.habits_title") %></h2>
<% @habits_by_category.each do |category, habits| %>
  <h2><%= category.name %></h2>
  <% habits.each do |habit| %>
    <div id="<%= dom_id(habit) %>">
      <span><%= habit.name %></span>
      <% if habit.active? %>
        <%= button_to t("user_habits.index.deactivate"), deactivate_user_habit_path(habit), method: :patch %>
      <% else %>
        <%= button_to t("user_habits.index.activate"), activate_user_habit_path(habit), method: :patch %>
      <% end %>
    </div>
  <% end %>
<% end %>

<hr>

<h2><%= t("user_habits.index.templates_title") %></h2>
<% @templates.each do |template| %>
  <div id="<%= dom_id(template) %>">
    <span><%= t("habits.templates.#{template.code}.name", default: template.code.humanize) %></span>
    <%= form_with url: create_from_template_user_habits_path, method: :post do |f| %>
      <%= hidden_field_tag :template_id, template.id %>
      <div>
        <%= label_tag :habit_category_id, t("user_habits.index.category_label") %>
        <%= select_tag :habit_category_id, options_from_collection_for_select(@categories, :id, :name) %>
      </div>
      <%= f.submit t("user_habits.index.add_from_template_submit") %>
    <% end %>
  </div>
<% end %>

