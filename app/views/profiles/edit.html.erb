<h1>Edit Profile</h1>

<%= form_with(model: @user, url: profile_path, method: :patch) do |form| %>
  <% if @user.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(@user.errors.count, "error") %> prohibited your profile from being saved:</h2>

      <ul>
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :date_of_birth, style: "display: block" %>
    <%= form.date_field :date_of_birth, required: true %>
  </div>

  <div data-controller="timezone">
    <%= form.label :timezone, style: "display: block" %>
    <%= form.text_field :timezone, required: true, data: { timezone_target: "input" } %>
  </div>

  <div>
    <%= form.submit "Update Profile" %>
  </div>
<% end %>
